# Required environment variables
# Copy this file to .env and fill in the values (never commit .env)

# PostgreSQL connection string (Supabase or Neon)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DB_URL=postgresql://postgres:your_password@db.xxxx.supabase.co:5432/postgres?sslmode=require

# Supabase JWKS endpoint for JWT validation
# Find in: Supabase Dashboard -> Project Settings -> API -> JWT Settings
# Format: https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=https://xxxxxxxxxxxx.supabase.co/auth/v1/.well-known/jwks.json

# Server port (Render sets this automatically)
PORT=8080
